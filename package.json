{
  "name": "lemon-new-tab",
  "version": "3.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "dev:edge": "wxt -b edge",
    "build": "vue-tsc --build && wxt build",
    "build:firefox": "vue-tsc --build && wxt build -b firefox",
    "build:edge": "vue-tsc --build && wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "postinstall": "wxt prepare",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint:style": "stylelint **/*.{css,scss,sass,less,vue,html} --fix --ignore-path .gitignore",
    "lint": "run-s lint:*",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "dayjs": "^1.11.21",
    "dayjs-plugin-lunar": "^1.4.1",
    "element-plus": "^2.14.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-vue": "^5.4.0",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/fluent": "^1.2.48",
    "@iconify-json/ic": "^1.2.4",
    "@material/material-color-utilities": "^0.4.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "@wxt-dev/webextension-polyfill": "^1.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.67.0",
    "eslint-plugin-vue": "^10.9.1",
    "markdown-exit": "latest",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "postcss": "^8.5.15",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.1.1",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^32.0.0",
    "vite": "^8.0.14",
    "vite-plugin-i18next-loader": "^3.1.3",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.3.2",
    "webextension-polyfill": "^0.12.0",
    "wxt": "^0.20.26"
  }
}
